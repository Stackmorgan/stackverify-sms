{
  "name": "stackverify-sms",
  "version": "1.0.0",
  "description": "Official Node.js SDK for StackVerify SMS API",
  "type": "module",

  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "sideEffects": false,

  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },

  "keywords": [
    "stackverify",
    "sms",
    "sms-api",
    "messaging",
    "nodejs",
    "typescript",
    "sdk"
  ],

  "author": "StackVerify",
  "license": "MIT",
  "homepage": "https://stackverify.site",

  "repository": {
    "type": "git",
    "url": "https://github.com/stackmorgan/stackverify-sms.git"
  },

  "bugs": {
    "url": "https://github.com/stackmorgan/stackverify-sms/issues"
  },

  "engines": {
    "node": ">=18"
  },

  "devDependencies": {
    "tsup": "^7.2.0",
    "typescript": "^5.3.0"
  }
}