{
  "name": "stackverify-sms",
  "version": "1.0.0",
  "description": "Official Node.js SDK for StackVerify SMS API — send text messages, OTPs, and notifications via REST API with automatic retries and TypeScript support",
  "type": "module",

  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "sideEffects": false,

  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },

  "keywords": [
    "stackverify",
    "sms",
    "sms-api",
    "messaging",
    "nodejs",
    "node",
    "typescript",
    "ts",
    "sdk",
    "text-message",
    "text-messaging",
    "bulk-sms",
    "sms-gateway",
    "sms-service",
    "transactional-sms",
    "otp",
    "one-time-password",
    "verification",
    "two-factor-authentication",
    "2fa",
    "notifications",
    "alert",
    "sms-provider",
    "sms-platform",
    "africa-sms",
    "african-sms-api",
    "mobile-messaging",
    "cloud-sms",
    "rest-api",
    "http-client",
    "esm",
    "cjs",
    "commonjs",
    "promise",
    "async",
    "await",
    "fetch",
    "api-client",
    "developer-tools",
    "open-source"
  ],

  "author": "StackVerify",
  "license": "MIT",
  "homepage": "https://stackverify.site",

  "repository": {
    "type": "git",
    "url": "https://github.com/stackmorgan/stackverify-sms.git"
  },

  "bugs": {
    "url": "https://github.com/stackmorgan/stackverify-sms/issues"
  },

  "engines": {
    "node": ">=18"
  },

  "devDependencies": {
    "tsup": "^7.2.0",
    "typescript": "^5.3.0"
  }
}